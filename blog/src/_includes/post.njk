---
layout: base.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.haggath.re/" },
    { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://www.haggath.re/blog/" },
    { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "https://www.haggath.re/blog{{ page.url }}" }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "{{ excerpt or description }}",
  "datePublished": "{{ date | htmlDateString }}",
  "dateModified": "{{ (updated or date) | htmlDateString }}",
  "image": "https://www.haggath.re/assets/og-card.jpg",
  "url": "https://www.haggath.re/blog{{ page.url }}",
  "author": {
    "@type": "Person",
    "name": "Thomas Haggath",
    "url": "https://www.haggath.re"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Thomas Haggath",
    "url": "https://www.haggath.re"
  }
}
</script>
<div class="blog-prose">
  <a href="/blog/" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"/></svg>
    All posts
  </a>
  <h1>{{ title }}</h1>
  <p class="post-meta">{{ date | readableDate }} &middot; {{ content | readingTime }} min read</p>
  {{ content | safe }}
</div>
