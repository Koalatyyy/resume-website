<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | Thomas Haggath</title>
  <meta name="description" content="{{ description or excerpt or 'Writing on AWS security, threat detection, and cloud defence by Thomas Haggath.' }}">

  {% if noindex %}<meta name="robots" content="noindex">{% endif %}
  <link rel="canonical" href="https://www.haggath.re/blog{{ page.url }}">

  <meta property="og:type"        content="{{ ogType or 'article' }}">
  <meta property="og:site_name"   content="Thomas Haggath">
  <meta property="og:title"       content="{{ title }}">
  <meta property="og:description" content="{{ description or excerpt or 'Writing on AWS security, threat detection, and cloud defence by Thomas Haggath.' }}">
  <meta property="og:url"         content="https://www.haggath.re/blog{{ page.url }}">
  <meta property="og:image"       content="https://www.haggath.re/assets/og-card.jpg">
  <meta property="og:image:alt"   content="Thomas Haggath — AWS Security Writing">
  <meta property="og:locale"      content="en_US">

  <meta name="twitter:card"        content="summary_large_image">
  <meta name="twitter:site"        content="@Koalatyyy">
  <meta name="twitter:creator"     content="@Koalatyyy">
  <meta name="twitter:title"       content="{{ title }}">
  <meta name="twitter:description" content="{{ description or excerpt or 'Writing on AWS security, threat detection, and cloud defence by Thomas Haggath.' }}">
  <meta name="twitter:image"       content="https://www.haggath.re/assets/og-card.jpg">

  <link rel="preload" href="/blog/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/blog/style.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/prismjs@1/themes/prism-tomorrow.css">
  <style>
    pre[class*="language-"] {
      border-radius: var(--radius);
      border: 1px solid var(--border);
      font-size: 0.875rem;
      margin-bottom: 1.25rem;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
    code[class*="language-"] {
      font-size: 0.875rem;
    }
  </style>
  <style>
    .blog-prose {
      max-width: 680px;
      margin-inline: auto;
      padding-block: calc(var(--nav-height) + 3rem) 4rem;
      padding-inline: 1.5rem;
    }
    .blog-prose h1 {
      font-size: clamp(1.5rem, 4vw, 2.25rem);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 0.75rem;
      color: var(--text);
    }
    .blog-prose .post-meta {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-bottom: 2.5rem;
    }
    .blog-prose h2 { font-size: 1.375rem; font-weight: 600; margin: 2rem 0 0.75rem; color: var(--text); }
    .blog-prose h3 { font-size: 1.125rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--text); }
    .blog-prose p  { margin-bottom: 1.25rem; color: var(--text); }
    .blog-prose ul, .blog-prose ol { padding-left: 1.5rem; margin-bottom: 1.25rem; list-style: revert; }
    .blog-prose li { margin-bottom: 0.4rem; }
    .blog-prose a  { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    .blog-prose a:hover { color: var(--accent-hover); }
    .blog-prose code {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.15em 0.4em;
      font-size: 0.875em;
    }
    .blog-prose pre {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
      margin-bottom: 1.25rem;
    }
    .blog-prose pre code { background: none; border: none; padding: 0; font-size: 0.875rem; }
    .blog-prose blockquote {
      border-left: 3px solid var(--accent);
      padding-left: 1rem;
      color: var(--text-muted);
      margin-bottom: 1.25rem;
    }
    .post-list { list-style: none; padding: 0; }
    .post-list li { border-bottom: 1px solid var(--border); padding-block: 1.5rem; }
    .post-list li:last-child { border-bottom: none; }
    .post-list .post-title { font-size: 1.125rem; font-weight: 600; color: var(--text); }
    .post-list .post-title:hover { color: var(--accent); }
    .post-list .post-date { font-size: 0.8125rem; color: var(--text-muted); margin-top: 0.25rem; }
    .post-list .post-excerpt { font-size: 0.9375rem; color: var(--text-muted); margin-top: 0.5rem; }
    .blog-prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.25rem; font-size: 0.9375rem; }
    .blog-prose th, .blog-prose td { border: 1px solid var(--border); padding: 0.6rem 0.875rem; text-align: left; color: var(--text); }
    .blog-prose th { background: var(--surface); font-weight: 600; }
    .back-link { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: var(--text-muted); margin-bottom: 2rem; }
    .back-link:hover { color: var(--accent); }
  </style>
</head>
<body>
  <header id="navbar">
    <nav class="nav-inner">
      <a href="/" class="nav-logo" aria-label="Home">TH</a>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <ul class="nav-links" id="navLinks" role="list">
        <li><a href="/#about">About</a></li>
        <li><a href="/#experience">Experience</a></li>
        <li><a href="/#skills">Skills</a></li>
        <li><a href="/#education">Education</a></li>
        <li><a href="/#projects">Projects</a></li>
        <li><a href="/blog/" class="active">Writing</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
      <button class="theme-toggle" id="themeToggle" aria-label="Switch to light mode">
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a href="/Thomas_Haggath-Resume-Chicago-IL.pdf" download class="btn btn-outline btn-sm nav-cta">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download <span class="cv-term">CV</span>
      </a>
    </nav>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <script>
    // Mobile nav toggle
    const toggle = document.getElementById('navToggle');
    const links  = document.getElementById('navLinks');
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      links.classList.toggle('open', !open);
    });
    // Scrolled state for navbar shadow
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      navbar.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
    // Theme toggle (mirrors main site logic)
    const themeToggle = document.getElementById('themeToggle');
    const root = document.documentElement;
    const saved = localStorage.getItem('theme');
    if (saved) root.setAttribute('data-theme', saved);
    themeToggle.addEventListener('click', () => {
      const current = root.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';
      root.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
    });
  </script>
</body>
</html>
